# ── Glow with Azmir backend — environment ──────────────────────────────────
# Copy this file to ".env" and fill in values. None are required for local dev
# (an in-memory MongoDB is used automatically when MONGODB_URI is empty).

# MongoDB connection string (MongoDB Atlas / Railway). Leave empty for local
# in-memory dev DB.
MONGODB_URI=

# Port the API listens on.
PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
# Use * to allow all (fine for internal use). In production set your panel URL.
CORS_ORIGIN=*

# OPTIONAL light protection (no login UI). If set, every write request must
# send header  x-api-key: <this value>. Leave empty to keep the API open.
# The frontend reads this from VITE_API_KEY.
API_KEY=

# Public base URL where this backend is reachable (used to build upload URLs).
# Local: http://localhost:4000   Production: https://your-backend.up.railway.app
PUBLIC_URL=http://localhost:4000

# Where uploaded files (advertise .mp4, gallery images) are stored on disk.
# NOTE: hosts like Railway have ephemeral disks — for production use S3/Cloudinary.
UPLOAD_DIR=uploads
