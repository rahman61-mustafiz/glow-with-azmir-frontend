# Glow with Azmir frontend — environment
# Copy to ".env" and adjust.

# Base URL of the Glow backend API.
#   Local:      http://localhost:4000/api
#   Production:  https://your-backend.up.railway.app/api
VITE_API_BASE=http://localhost:4000/api

# Optional: set only if the backend runs in protected mode (API_KEY set there).
VITE_API_KEY=
